# Copy this file to ".env" and fill in real values for LOCAL development.
# On Render, set these in the dashboard (Environment tab) instead of a .env file.

# A long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-with-a-long-random-string

# True for local development, False in production (Render).
DEBUG=True

# Space-separated hostnames. Local can stay as-is; on Render set your domain,
# e.g. ALLOWED_HOSTS=your-app.onrender.com
ALLOWED_HOSTS=127.0.0.1 localhost

# Postgres connection string.
#   Local:  postgresql://postgres:PASSWORD@localhost:5432/rate_code
#   Render: use the managed Postgres "Internal/External Database URL" and add ?sslmode=require
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/rate_code

# Hugging Face token with "Make calls to Inference Providers" permission.
# Leave UNSET on the public deploy to disable code reviewing (stops bots from
# spending your inference credits); the dashboard still works read-only.
HUGGINGFACEHUB_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxx
